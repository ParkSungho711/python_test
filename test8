class QuizApp:
    def __init__(self, root):
        self.root = root
        self.root.title("파이썬 코딩활용능력 1급 (Hardcore Level 40제)")
        self.root.geometry("850x700")
        self.root.configure(bg="#0F172A") # 다크 터미널 배경
        
        self.score = 0
        self.current_question_idx = 0
        self.wrong_answers = [] 
        
        # 타이틀 바 (다크 모드 + 네온 그린 포인트)
        self.title_frame = tk.Frame(root, bg="#000000", pady=15)
        self.title_frame.pack(fill="x")
        self.title_label = tk.Label(self.title_frame, text=">_ PYTHON EXPERT : HARDCORE 40", font=("Consolas", 18, "bold"), fg="#10B981", bg="#000000")
        self.title_label.pack()

        # 중앙 카드 프레임
        self.card_frame = tk.Frame(root, bg="#1E293B", padx=30, pady=30, highlightbackground="#334155", highlightthickness=2)
        self.card_frame.pack(fill="both", expand=True, padx=40, pady=30)
        
        self.progress_label = tk.Label(self.card_frame, text="", font=("Consolas", 12, "bold"), fg="#94A3B8", bg="#1E293B")
        self.progress_label.pack(anchor="e", pady=(0, 10))

        self.question_label = tk.Label(self.card_frame, text="", font=("Consolas", 13), fg="#F8FAFC", bg="#1E293B", justify="left", wraplength=700)
        self.question_label.pack(anchor="w", pady=(0, 20))
        
        self.options_frame = tk.Frame(self.card_frame, bg="#1E293B")
        self.options_frame.pack(fill="x", pady=10)
        
        self.var = tk.IntVar()
        self.radio_buttons = []
        for i in range(4):
            rb = tk.Radiobutton(self.options_frame, text="", variable=self.var, value=i, 
                                font=("Consolas", 11), fg="#CBD5E1", bg="#1E293B",
                                activebackground="#1E293B", activeforeground="#10B981", selectcolor="#475569",
                                justify="left", wraplength=650)
            rb.pack(anchor="w", pady=6)
            self.radio_buttons.append(rb)
            
        self.button_frame = tk.Frame(self.card_frame, bg="#1E293B")
        self.button_frame.pack(fill="x", pady=(20, 0))

        self.hint_visible = False
        self.hint_button = tk.Button(self.button_frame, text="[?] DEBUG HINT", command=self.toggle_hint, 
                                     font=("Consolas", 11, "bold"), bg="#334155", fg="#FBBF24", 
                                     activebackground="#475569", activeforeground="#FCD34D", relief="flat", cursor="hand2", padx=15, pady=8)
        self.hint_button.pack(side="left")
        
        self.next_button = tk.Button(self.button_frame, text="EXECUTE NEXT >", command=self.next_question, 
                                     font=("Consolas", 11, "bold"), bg="#059669", fg="white", 
                                     activebackground="#047857", relief="flat", cursor="hand2", padx=20, pady=8)
        self.next_button.pack(side="right")
        
        self.hint_label = tk.Label(self.card_frame, text="", font=("Consolas", 11, "italic"), fg="#A7F3D0", bg="#064E3B", 
                                   justify="left", wraplength=700, padx=12, pady=12)

        self.load_question()

    def toggle_hint(self):
        if self.hint_visible:
            self.hint_label.pack_forget()
            self.hint_button.config(text="[?] DEBUG HINT")
            self.hint_visible = False
        else:
            self.hint_label.pack(before=self.button_frame, fill="x", pady=(0, 15))
            self.hint_button.config(text="[x] HIDE HINT")
            self.hint_visible = True

    def load_question(self):
        self.var.set(-1) 
        if self.hint_visible:
            self.toggle_hint()
            
        q_data = quiz_data[self.current_question_idx]
        self.progress_label.config(text=f"Process {self.current_question_idx + 1} / {len(quiz_data)}")
        self.question_label.config(text=q_data["question"])
        self.hint_label.config(text=f"// HINT: {q_data['hint']}")
        
        for i in range(4):
            self.radio_buttons[i].config(text=q_data["options"][i])
            
        if self.current_question_idx == len(quiz_data) - 1:
            self.next_button.config(text="COMPILE RESULT", bg="#DC2626", activebackground="#B91C1C")

    def next_question(self):
        selected_option = self.var.get()
        if selected_option == -1:
            messagebox.showwarning("System Alert", "답안이 선택되지 않았습니다.")
            return
            
        q_data = quiz_data[self.current_question_idx]
        correct_answer = q_data["answer"]
        
        if selected_option == correct_answer:
            self.score += 1
        else:
            self.wrong_answers.append({
                "question": q_data["question"],
                "my_answer": q_data["options"][selected_option],
                "correct_answer": q_data["options"][correct_answer]
            })
            
        self.current_question_idx += 1
        if self.current_question_idx < len(quiz_data):
            self.load_question()
        else:
            self.show_result()

    def show_result(self):
        self.title_frame.destroy()
        self.card_frame.destroy()
        
        result_card = tk.Frame(self.root, bg="#1E293B", padx=30, pady=30, highlightbackground="#334155", highlightthickness=2)
        result_card.pack(fill="both", expand=True, padx=40, pady=40)
        
        score_text = f"=== EXECUTION COMPLETED ===\n\nTotal {len(quiz_data)} Tasks / Score: {self.score}"
        score_label = tk.Label(result_card, text=score_text, font=("Consolas", 18, "bold"), fg="#10B981", bg="#1E293B")
        score_label.pack(pady=(0, 20))
        
        if self.wrong_answers:
            wrong_label = tk.Label(result_card, text="[ ERROR LOG ]", font=("Consolas", 14, "bold"), bg="#1E293B", fg="#EF4444")
            wrong_label.pack(anchor="w", pady=(0, 10))
            
            st = scrolledtext.ScrolledText(result_card, wrap=tk.WORD, font=("Consolas", 11), bg="#0F172A", fg="#E2E8F0", padx=15, pady=15, insertbackground="white")
            st.pack(fill="both", expand=True)
            
            for idx, wrong in enumerate(self.wrong_answers, 1):
                st.insert(tk.END, f"[FATAL] Task {idx}:\n{wrong['question']}\n\n")
                st.insert(tk.END, f"> Output: {wrong['my_answer']}\n")
                st.insert(tk.END, f"> Expected: {wrong['correct_answer']}\n")
                st.insert(tk.END, "="*60 + "\n\n")
                
            st.config(state="disabled")
        else:
            perfect_label = tk.Label(result_card, text="SYSTEM CLEAR! 0 Errors Found.", font=("Consolas", 16, "bold"), fg="#10B981", bg="#1E293B")
            perfect_label.pack(pady=40)

        exit_button = tk.Button(result_card, text="SHUTDOWN", command=self.root.destroy, 
                                font=("Consolas", 12, "bold"), bg="#EF4444", fg="white", 
                                activebackground="#DC2626", relief="flat", cursor="hand2", padx=25, pady=12)
        exit_button.pack(pady=(20, 0))

if __name__ == "__main__":
    root = tk.Tk()
    app = QuizApp(root)
    root.mainloop()
