class QuizApp:
    def __init__(self, root):
        self.root = root
        self.root.title("파이썬 코딩활용능력 1급 모의고사 (최고난도 코드 추적)")
        self.root.geometry("850x700") # 창 크기
        self.root.configure(bg="#111827") # 다크 해커 배경색
        
        self.score = 0
        self.current_question_idx = 0
        self.wrong_answers = [] 
        
        # 상단 타이틀 바 (다크 모드 네온 그린)
        self.title_frame = tk.Frame(root, bg="#000000", pady=15)
        self.title_frame.pack(fill="x")
        self.title_label = tk.Label(self.title_frame, text="💻 파이썬 코딩활용능력 1급 - EXPERT LEVEL", font=("Consolas", 16, "bold"), fg="#10B981", bg="#000000")
        self.title_label.pack()

        # 중앙 카드 프레임
        self.card_frame = tk.Frame(root, bg="#1F2937", padx=30, pady=30, highlightbackground="#374151", highlightthickness=2)
        self.card_frame.pack(fill="both", expand=True, padx=40, pady=30)
        
        self.progress_label = tk.Label(self.card_frame, text="", font=("Consolas", 11, "bold"), fg="#9CA3AF", bg="#1F2937")
        self.progress_label.pack(anchor="e", pady=(0, 10))

        # 문제 출력 영역 (코드 폰트로 변경)
        self.question_label = tk.Label(self.card_frame, text="", font=("Consolas", 12), fg="#F3F4F6", bg="#1F2937", justify="left", wraplength=700)
        self.question_label.pack(anchor="w", pady=(0, 20))
        
        self.options_frame = tk.Frame(self.card_frame, bg="#1F2937")
        self.options_frame.pack(fill="x", pady=10)
        
        self.var = tk.IntVar()
        self.radio_buttons = []
        for i in range(4):
            rb = tk.Radiobutton(self.options_frame, text="", variable=self.var, value=i, 
                                font=("Consolas", 11), fg="#D1D5DB", bg="#1F2937",
                                activebackground="#1F2937", activeforeground="#10B981", selectcolor="#374151",
                                justify="left", wraplength=650)
            rb.pack(anchor="w", pady=6)
            self.radio_buttons.append(rb)
            
        self.button_frame = tk.Frame(self.card_frame, bg="#1F2937")
        self.button_frame.pack(fill="x", pady=(20, 0))

        # 힌트 버튼
        self.hint_visible = False
        self.hint_button = tk.Button(self.button_frame, text="💡 힌트 해독 (Hint)", command=self.toggle_hint, 
                                     font=("맑은 고딕", 10, "bold"), bg="#4B5563", fg="#FBBF24", 
                                     activebackground="#374151", activeforeground="#FCD34D", relief="flat", cursor="hand2", padx=10, pady=5)
        self.hint_button.pack(side="left")
        
        # 다음 버튼
        self.next_button = tk.Button(self.button_frame, text="EXECUTE_NEXT() ➔", command=self.next_question, 
                                     font=("Consolas", 11, "bold"), bg="#059669", fg="white", 
                                     activebackground="#047857", relief="flat", cursor="hand2", padx=15, pady=5)
        self.next_button.pack(side="right")
        
        # 힌트 텍스트
        self.hint_label = tk.Label(self.card_frame, text="", font=("맑은 고딕", 10), fg="#A7F3D0", bg="#064E3B", 
                                   justify="left", wraplength=700, padx=10, pady=10)

        self.load_question()

    def toggle_hint(self):
        if self.hint_visible:
            self.hint_label.pack_forget()
            self.hint_button.config(text="💡 힌트 해독 (Hint)")
            self.hint_visible = False
        else:
            self.hint_label.pack(before=self.button_frame, fill="x", pady=(0, 15))
            self.hint_button.config(text="💡 힌트 은닉 (Hide)")
            self.hint_visible = True

    def load_question(self):
        self.var.set(-1) 
        
        if self.hint_visible:
            self.toggle_hint()
            
        q_data = quiz_data[self.current_question_idx]
        
        self.progress_label.config(text=f"Task {self.current_question_idx + 1} / {len(quiz_data)}")
        self.question_label.config(text=q_data["question"])
        self.hint_label.config(text=f"// Debugger Hint: {q_data['hint']}")
        
        for i in range(4):
            self.radio_buttons[i].config(text=q_data["options"][i])
            
        if self.current_question_idx == len(quiz_data) - 1:
            self.next_button.config(text="COMPILE_RESULTS() ✔️", bg="#DC2626", activebackground="#B91C1C")

    def next_question(self):
        selected_option = self.var.get()
        
        if selected_option == -1:
            messagebox.showwarning("System Error", "답을 선택하지 않았습니다. (No Selection)")
            return
            
        q_data = quiz_data[self.current_question_idx]
        correct_answer = q_data["answer"]
        
        if selected_option == correct_answer:
            self.score += 1
        else:
            self.wrong_answers.append({
                "question": q_data["question"],
                "my_answer": q_data["options"][selected_option],
                "correct_answer": q_data["options"][correct_answer]
            })
            
        self.current_question_idx += 1
        
        if self.current_question_idx < len(quiz_data):
            self.load_question()
        else:
            self.show_result()

    def show_result(self):
        self.title_frame.destroy()
        self.card_frame.destroy()
        
        result_card = tk.Frame(self.root, bg="#1F2937", padx=30, pady=30, highlightbackground="#374151", highlightthickness=2)
        result_card.pack(fill="both", expand=True, padx=40, pady=40)
        
        score_text = f"=== SYSTEM TERMINATED ===\n\n총 {len(quiz_data)}개의 Task 중 {self.score}개를 디버깅했습니다."
        score_label = tk.Label(result_card, text=score_text, font=("Consolas", 15, "bold"), fg="#10B981", bg="#1F2937")
        score_label.pack(pady=(0, 20))
        
        if self.wrong_answers:
            wrong_label = tk.Label(result_card, text="[ ERROR LOGS / 오답 노트 ]", font=("Consolas", 12, "bold"), bg="#1F2937", fg="#F87171")
            wrong_label.pack(anchor="w", pady=(0, 10))
            
            st = scrolledtext.ScrolledText(result_card, wrap=tk.WORD, font=("Consolas", 10), bg="#111827", fg="#E5E7EB", padx=10, pady=10, insertbackground="white")
            st.pack(fill="both", expand=True)
            
            for idx, wrong in enumerate(self.wrong_answers, 1):
                st.insert(tk.END, f"[FATAL] Task {idx}:\n{wrong['question']}\n\n")
                st.insert(tk.END, f"-> User Input : {wrong['my_answer']}\n")
                st.insert(tk.END, f"-> Valid Output: {wrong['correct_answer']}\n")
                st.insert(tk.END, "-"*60 + "\n\n")
                
            st.config(state="disabled")
        else:
            perfect_label = tk.Label(result_card, text="System Clear! 버그가 존재하지 않습니다.", font=("Consolas", 14, "bold"), fg="#34D399", bg="#1F2937")
            perfect_label.pack(pady=40)

        exit_button = tk.Button(result_card, text="EXIT_PROGRAM()", command=self.root.destroy, 
                                font=("Consolas", 12, "bold"), bg="#EF4444", fg="white", 
                                activebackground="#DC2626", relief="flat", cursor="hand2", padx=20, pady=10)
        exit_button.pack(pady=(20, 0))

# 실행
if __name__ == "__main__":
    root = tk.Tk()
    app = QuizApp(root)
    root.mainloop()
