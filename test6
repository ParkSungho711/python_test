class QuizApp:
    def __init__(self, root):
        self.root = root
        self.root.title("파이썬 코딩활용능력 1급 (실전 흐름 추적 40제)")
        self.root.geometry("850x660")
        self.root.configure(bg="#F0FDFA") # 아주 연한 민트색 배경
        
        self.score = 0
        self.current_question_idx = 0
        self.wrong_answers = [] 
        
        # 타이틀 바 (진한 틸/청록색)
        self.title_frame = tk.Frame(root, bg="#0D9488", pady=15)
        self.title_frame.pack(fill="x")
        self.title_label = tk.Label(self.title_frame, text="파이썬 실전 흐름 추적 40제 (V2)", font=("맑은 고딕", 16, "bold"), fg="white", bg="#0D9488")
        self.title_label.pack()

        # 중앙 카드 프레임
        self.card_frame = tk.Frame(root, bg="white", padx=30, pady=30, highlightbackground="#99F6E4", highlightthickness=2)
        self.card_frame.pack(fill="both", expand=True, padx=40, pady=30)
        
        self.progress_label = tk.Label(self.card_frame, text="", font=("맑은 고딕", 11, "bold"), fg="#64748B", bg="white")
        self.progress_label.pack(anchor="e", pady=(0, 15))

        self.question_label = tk.Label(self.card_frame, text="", font=("Consolas", 12, "bold"), fg="#0F172A", bg="white", justify="left", wraplength=700)
        self.question_label.pack(anchor="w", pady=(0, 20))
        
        self.options_frame = tk.Frame(self.card_frame, bg="white")
        self.options_frame.pack(fill="x", pady=10)
        
        self.var = tk.IntVar()
        self.radio_buttons = []
        for i in range(4):
            rb = tk.Radiobutton(self.options_frame, text="", variable=self.var, value=i, 
                                font=("맑은 고딕", 11), fg="#334155", bg="white",
                                activebackground="white", selectcolor="white",
                                justify="left", wraplength=650)
            rb.pack(anchor="w", pady=6)
            self.radio_buttons.append(rb)
            
        self.button_frame = tk.Frame(self.card_frame, bg="white")
        self.button_frame.pack(fill="x", pady=(20, 0))

        self.hint_visible = False
        self.hint_button = tk.Button(self.button_frame, text="💡 힌트 보기", command=self.toggle_hint, 
                                     font=("맑은 고딕", 10, "bold"), bg="#FDE047", fg="#A16207", 
                                     activebackground="#FACC15", relief="flat", cursor="hand2", padx=10, pady=5)
        self.hint_button.pack(side="left")
        
        self.next_button = tk.Button(self.button_frame, text="다음 문제 ➔", command=self.next_question, 
                                     font=("맑은 고딕", 11, "bold"), bg="#0D9488", fg="white", 
                                     activebackground="#0F766E", relief="flat", cursor="hand2", padx=15, pady=5)
        self.next_button.pack(side="right")
        
        self.hint_label = tk.Label(self.card_frame, text="", font=("맑은 고딕", 10, "italic"), fg="#0F766E", bg="#CCFBF1", 
                                   justify="left", wraplength=700, padx=10, pady=10)

        self.load_question()

    def toggle_hint(self):
        if self.hint_visible:
            self.hint_label.pack_forget()
            self.hint_button.config(text="💡 힌트 보기")
            self.hint_visible = False
        else:
            self.hint_label.pack(before=self.button_frame, fill="x", pady=(0, 15))
            self.hint_button.config(text="💡 힌트 닫기")
            self.hint_visible = True

    def load_question(self):
        self.var.set(-1) 
        if self.hint_visible:
            self.toggle_hint()
            
        q_data = quiz_data[self.current_question_idx]
        self.progress_label.config(text=f"진행 상황: {self.current_question_idx + 1} / {len(quiz_data)}")
        self.question_label.config(text=q_data["question"])
        self.hint_label.config(text=f"힌트: {q_data['hint']}")
        
        for i in range(4):
            self.radio_buttons[i].config(text=q_data["options"][i])
            
        if self.current_question_idx == len(quiz_data) - 1:
            self.next_button.config(text="최종 결과 확인 ✔️", bg="#E11D48", activebackground="#BE123C")

    def next_question(self):
        selected_option = self.var.get()
        if selected_option == -1:
            messagebox.showwarning("안내", "답을 하나 선택해 주세요!")
            return
            
        q_data = quiz_data[self.current_question_idx]
        correct_answer = q_data["answer"]
        
        if selected_option == correct_answer:
            self.score += 1
        else:
            self.wrong_answers.append({
                "question": q_data["question"],
                "my_answer": q_data["options"][selected_option],
                "correct_answer": q_data["options"][correct_answer]
            })
            
        self.current_question_idx += 1
        if self.current_question_idx < len(quiz_data):
            self.load_question()
        else:
            self.show_result()

    def show_result(self):
        self.title_frame.destroy()
        self.card_frame.destroy()
        
        result_card = tk.Frame(self.root, bg="white", padx=30, pady=30, highlightbackground="#99F6E4", highlightthickness=2)
        result_card.pack(fill="both", expand=True, padx=40, pady=40)
        
        score_text = f"🎉 40문제 완주를 축하합니다!\n\n총 {len(quiz_data)}문제 중 {self.score}문제를 맞췄습니다."
        score_label = tk.Label(result_card, text=score_text, font=("맑은 고딕", 16, "bold"), fg="#0D9488", bg="white")
        score_label.pack(pady=(0, 20))
        
        if self.wrong_answers:
            wrong_label = tk.Label(result_card, text="[ 오답 노트 ]", font=("맑은 고딕", 12, "bold"), bg="white", fg="#475569")
            wrong_label.pack(anchor="w", pady=(0, 10))
            
            st = scrolledtext.ScrolledText(result_card, wrap=tk.WORD, font=("Consolas", 11), bg="#F8FAFC", fg="#0F172A", padx=10, pady=10)
            st.pack(fill="both", expand=True)
            
            for idx, wrong in enumerate(self.wrong_answers, 1):
                st.insert(tk.END, f"❌ 틀린 문제 {idx}:\n{wrong['question']}\n\n")
                st.insert(tk.END, f"내가 고른 답 : {wrong['my_answer']}\n")
                st.insert(tk.END, f"정답         : {wrong['correct_answer']}\n")
                st.insert(tk.END, "="*60 + "\n\n")
                
            st.config(state="disabled")
        else:
            perfect_label = tk.Label(result_card, text="💯 대단합니다! 40문제 모두 정답입니다.", font=("맑은 고딕", 14, "bold"), fg="#059669", bg="white")
            perfect_label.pack(pady=40)

        exit_button = tk.Button(result_card, text="프로그램 종료", command=self.root.destroy, 
                                font=("맑은 고딕", 12, "bold"), bg="#64748B", fg="white", 
                                activebackground="#475569", relief="flat", cursor="hand2", padx=20, pady=10)
        exit_button.pack(pady=(20, 0))

if __name__ == "__main__":
    root = tk.Tk()
    app = QuizApp(root)
    root.mainloop()
